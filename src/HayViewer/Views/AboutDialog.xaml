<Window x:Class="HayViewer.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Hay Viewer"
        Width="400" Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="24" VerticalAlignment="Center">
        <TextBlock Text="Hay Viewer" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock x:Name="VersionText" Foreground="Gray" Margin="0,0,0,16"/>
        <TextBlock Text="A portable JSON viewer &amp; editor for Windows." TextWrapping="Wrap" Margin="0,0,0,16"/>
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
            Third-party notices for AvalonEdit are in
            <Hyperlink x:Name="NoticesLink" Click="NoticesLink_Click">THIRD-PARTY-NOTICES.txt</Hyperlink>
            next to the executable.
        </TextBlock>
        <Button Content="OK" Width="80" HorizontalAlignment="Right"
                Margin="0,12,0,0" IsDefault="True" Click="OK_Click"/>
    </StackPanel>
</Window>
